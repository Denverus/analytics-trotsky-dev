PORT=3001
# Same Atlas cluster + database as platform-service — analytics-service reads apikeys from shared DB
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/console-trotsky-dev?retryWrites=true&w=majority
# Must match platform-service JWT_SECRET — analytics-service validates the same tokens
JWT_SECRET=change-me-access-secret
NODE_ENV=development
# Comma-separated allowed origins in production (e.g. https://console.trotsky.dev,https://playzoo.trotsky.dev)
ALLOWED_ORIGINS=
